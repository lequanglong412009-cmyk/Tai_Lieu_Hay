# Firebase client config for frontend
VITE_FIREBASE_API_KEY=REPLACE_WITH_YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_WITH_YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=REPLACE_WITH_YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=REPLACE_WITH_YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_WITH_YOUR_FIREBASE_APP_ID

# Firebase admin / backend
FIREBASE_SERVICE_ACCOUNT_KEY=REPLACE_WITH_ONE_LINE_STRINGIFIED_JSON
FIREBASE_PROJECT_ID=REPLACE_WITH_YOUR_FIREBASE_PROJECT_ID

# payOS backend secret keys
PAYOS_API_BASE=REPLACE_WITH_PAYOS_API_BASE_OR_DEFAULT
PAYOS_CLIENT_ID=REPLACE_WITH_YOUR_PAYOS_CLIENT_ID
PAYOS_API_KEY=REPLACE_WITH_YOUR_PAYOS_API_KEY
PAYOS_CHECKSUM_KEY=REPLACE_WITH_YOUR_PAYOS_CHECKSUM_KEY

# App URLs and payOS callback URLs
APP_URL=REPLACE_WITH_YOUR_WEBSITE_URL
PAYOS_RETURN_URL=REPLACE_WITH_YOUR_RETURN_URL
PAYOS_CANCEL_URL=REPLACE_WITH_YOUR_CANCEL_URL
PAYOS_WEBHOOK_URL=REPLACE_WITH_YOUR_WEBHOOK_URL

# Optional: enable debug logs in backend
BACKEND_DEBUG=false
